#!/usr/bin/env bash

layout go
layout ruby

PATH_add "./scripts"

if [ -n "$CI" ]; then
    exit 0
fi

# local development
export HUGO_CACHEDIR="${XDG_CACHE_HOME:-$TMPDIR}/hugo_cache"

PATH_add "/opt/homebrew/opt/asciidoctor/bin"
PATH_add "/opt/homebrew/opt/ruby/bin"
PATH_add "/opt/homebrew/opt/go/bin"
